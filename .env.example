# Map2Market Environment Configuration

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false

# Security
SECRET_KEY=your-super-secret-key-change-in-production-$(date +%s)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
# SQLite (default for development)
DATABASE_URL=sqlite:///./map2market.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost/map2market

# Model Configuration
MODEL_PATH=./models/business_model.pkl
FEATURES_PATH=./models/feature_names.pkl
ENSEMBLE_PATH=./models/ensemble_models.pkl

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/map2market.log

# API Configuration
CORS_ORIGINS=*
API_VERSION=1.0.0

# ML Model Configuration
MODEL_TRAINING_SAMPLES=300
MODEL_TEST_SIZE=0.2
MODEL_RANDOM_STATE=42

# Feature Engineering
USE_FEATURE_ENGINEERING=true
NORMALIZATION_TYPE=robust

# External APIs
OSM_API_ENABLED=false
OSM_BATCH_SIZE=50
OSM_TIMEOUT=30

# Heatmap Configuration
HEATMAP_RADIUS=60
HEATMAP_COLORS=blue,cyan,green,yellow,red

# Application Settings
APP_NAME=Map2Market
APP_DESCRIPTION=AI-Driven Business Feasibility System
TIMEZONE=Asia/Kolkata

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60
